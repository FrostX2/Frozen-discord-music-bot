# Required
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_id_here

# Optional (slash commands scope to specific guild for instant registration)
GUILD_ID=
PREFIX=!

# --- NodeLink (self-hosted audio server) ---
# These are the defaults — only set to override
# NODELINK_PORT=2333
# NODELINK_PASSWORD=youshallnotpass
# NODELINK_LOG_LEVEL=info
# SPOTIFY_CLIENT_ID=   (optional, enables Spotify source)
# SPOTIFY_CLIENT_SECRET=
# YOUTUBE_TV_REFRESH_TOKEN=   (optional, bypass YouTube geo-restrictions)

# --- External Lavalink (bypass local NodeLink) ---
# Set LAVALINK_HOST to skip starting NodeLink and connect to a remote server
# LAVALINK_HOST=lavalinkv4-eu.serenetia.com
# LAVALINK_PORT=443
# LAVALINK_PASSWORD=BatuManaBisa
# LAVALINK_SECURE=true

# Render
# PORT=3000
